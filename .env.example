# ─── AIVO Learning SaaS — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in the values.
# All variables use ${VAR:-default} in docker-compose.dev.yml so the stack
# boots without a .env file (services fail gracefully for missing secrets).

# ─── JWT (RS256 Keypair) ─────────────────────────────────────────────────────
# Generate with: scripts/dev-up.sh (auto-generates if missing)
# Or manually:
#   openssl genpkey -algorithm RSA -out jwt_private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ─── Identity Service ───────────────────────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-32-char-secret
APP_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (optional)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── Email (Oonrumail) ──────────────────────────────────────────────────────
# Used by identity-svc and comms-svc
OONRUMAIL_API_KEY=
OONRUMAIL_BASE_URL=https://api.oonrumail.com/v1

# ─── AI Service — LLM Provider Keys ─────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ─── AI Service — Model Routing ─────────────────────────────────────────────
REASONING_MODEL=anthropic/claude-sonnet-4-20250514
REASONING_FALLBACK_MODEL=google/gemini-2.0-flash
SMART_MODEL=anthropic/claude-sonnet-4-20250514
SMART_FALLBACK_MODEL=google/gemini-2.0-flash
FAST_MODEL=anthropic/claude-sonnet-4-20250514
FAST_FALLBACK_MODEL=google/gemini-2.0-flash
SELF_HOSTED_MODEL=ollama/llama3
VISION_MODEL=google/gemini-2.0-flash
VISION_FALLBACK_MODEL=openai/gpt-4o
IEP_PARSE_MODEL=anthropic/claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small
TOKEN_QUOTA_SOFT_LIMIT_PERCENT=80

# ─── AI Service — Langfuse Observability (optional) ─────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Billing Service — Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Comms Service — Firebase Cloud Messaging (optional) ────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Comms Service — Web Push VAPID (optional) ──────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=support@aivolearning.com

# ─── Integrations Service — Clever SSO (optional) ───────────────────────────
CLEVER_CLIENT_ID=
CLEVER_CLIENT_SECRET=
CLEVER_REDIRECT_URI=http://localhost:3010/integrations/clever/callback

# ─── Integrations Service — ClassLink SSO (optional) ────────────────────────
CLASSLINK_CLIENT_ID=
CLASSLINK_CLIENT_SECRET=
CLASSLINK_REDIRECT_URI=http://localhost:3010/integrations/classlink/callback

# ─── Integrations Service — LTI 1.3 (optional) ─────────────────────────────
LTI_PRIVATE_KEY=
LTI_PUBLIC_KEY=
LTI_KID=aivo-lti-key-1

# ─── AWS S3 (optional — family-svc exports, integrations-svc imports) ───────
AWS_S3_BUCKET=aivo-integrations
AWS_REGION=us-east-1
S3_BUCKET=aivo-family-exports
S3_REGION=us-east-1
