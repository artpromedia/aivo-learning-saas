# Server
PORT=5000
HOST=0.0.0.0
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://aivo:aivo_dev@localhost:5432/aivo_dev

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# JWT (RS256 public key for verification)
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256

# LLM Provider API Keys
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Tier model routing
REASONING_MODEL=anthropic/claude-sonnet-4-20250514
REASONING_FALLBACK_MODEL=google/gemini-2.0-flash
SMART_MODEL=anthropic/claude-sonnet-4-20250514
SMART_FALLBACK_MODEL=google/gemini-2.0-flash
FAST_MODEL=anthropic/claude-sonnet-4-20250514
FAST_FALLBACK_MODEL=google/gemini-2.0-flash
SELF_HOSTED_MODEL=ollama/llama3

# Vision AI
VISION_MODEL=google/gemini-2.0-flash
VISION_FALLBACK_MODEL=openai/gpt-4o

# IEP Parsing
IEP_PARSE_MODEL=anthropic/claude-sonnet-4-20250514

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Brain Service URL
BRAIN_SVC_URL=http://localhost:3002

# Token Quota
TOKEN_QUOTA_SOFT_LIMIT_PERCENT=80

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
