{
  "name": "@aivo/family-svc",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aivo/db": "workspace:*",
    "@aivo/events": "workspace:*",
    "drizzle-orm": "0.44.2",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.0",
    "jose": "^6.0.0",
    "nats": "^2.28.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.3.6",
    "tsx": "^4.19.0",
    "typescript": "~5.7.3",
    "vitest": "^3.0.0"
  },
  "tsup": {
    "entry": ["src/index.ts"],
    "format": ["esm"],
    "target": "node22",
    "sourcemap": true,
    "clean": true
  }
}
