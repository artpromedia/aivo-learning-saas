{
  "uid": "aivo-ai-llm",
  "title": "AIVO AI/LLM Costs & Performance",
  "tags": ["aivo"],
  "editable": true,
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(llm_tokens_used_total, provider)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "model",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(llm_tokens_used_total{provider=~\"$provider\"}, model)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Token Usage & Cost",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Token Usage (rate/hr by provider & model)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(llm_tokens_used_total{provider=~\"$provider\", model=~\"$model\"}[1h])) by (provider, model, type)",
          "legendFormat": "{{ provider }}/{{ model }} ({{ type }})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Estimated Cost ($/hr)",
      "description": "Cost estimated using per-token pricing: input tokens at provider rates, output tokens at provider rates. Adjust multipliers as pricing changes.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(llm_tokens_used_total{type=\"input\", provider=\"anthropic\", model=~\"$model\"}[1h])) * 0.000003 + sum(rate(llm_tokens_used_total{type=\"output\", provider=\"anthropic\", model=~\"$model\"}[1h])) * 0.000015",
          "legendFormat": "Anthropic",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(llm_tokens_used_total{type=\"input\", provider=\"openai\", model=~\"$model\"}[1h])) * 0.000005 + sum(rate(llm_tokens_used_total{type=\"output\", provider=\"openai\", model=~\"$model\"}[1h])) * 0.000015",
          "legendFormat": "OpenAI",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Tokens (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 1000000 },
              { "color": "red", "value": 10000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(increase(llm_tokens_used_total{provider=~\"$provider\", model=~\"$model\"}[24h]))",
          "legendFormat": "total tokens",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Estimated Cost (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 9 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(increase(llm_tokens_used_total{type=\"input\"}[24h])) * 0.000003 + sum(increase(llm_tokens_used_total{type=\"output\"}[24h])) * 0.000015",
          "legendFormat": "est. cost",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "LLM Requests (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 9 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(increase(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[24h]))",
          "legendFormat": "requests",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "LLM Error Rate",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 9 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(llm_requests_total{status=\"error\", provider=~\"$provider\"}[5m])) / sum(rate(llm_requests_total{provider=~\"$provider\"}[5m])) * 100",
          "legendFormat": "error %",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "LLM Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "LLM Latency p50 / p95 by Provider",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.50, sum(rate(llm_request_duration_seconds_bucket{provider=~\"$provider\"}[5m])) by (le, provider))",
          "legendFormat": "{{ provider }} p50",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.95, sum(rate(llm_request_duration_seconds_bucket{provider=~\"$provider\"}[5m])) by (le, provider))",
          "legendFormat": "{{ provider }} p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Content Generation by Session Type",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never",
            "spanNulls": false,
            "barAlignment": 0,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(llm_requests_total{provider=~\"$provider\"}[5m])) by (session_type)",
          "legendFormat": "{{ session_type }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Quality",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Quality Gate Pass/Fail Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pass" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "fail" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(quality_gate_evaluations_total{result=\"pass\"}[5m]))",
          "legendFormat": "pass",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(quality_gate_evaluations_total{result=\"fail\"}[5m]))",
          "legendFormat": "fail",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Quality Gate Pass Rate (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(quality_gate_evaluations_total{result=\"pass\"}[1h])) / sum(rate(quality_gate_evaluations_total[1h])) * 100",
          "legendFormat": "pass rate",
          "refId": "A"
        }
      ]
    }
  ]
}
