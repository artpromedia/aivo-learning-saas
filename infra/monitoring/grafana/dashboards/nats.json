{
  "uid": "aivo-nats",
  "title": "AIVO NATS JetStream",
  "tags": ["aivo"],
  "editable": true,
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "name": "stream",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(jetstream_stream_bytes, stream)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Message Rates",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Messages Published (rate/s by subject)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(nats_messages_published_total[5m])) by (subject)",
          "legendFormat": "pub {{ subject }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Messages Received (rate/s by subject)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(nats_messages_received_total[5m])) by (subject)",
          "legendFormat": "recv {{ subject }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Consumer Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Consumer Lag (pending messages)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "jetstream_consumer_num_pending{stream=~\"$stream\"}",
          "legendFormat": "{{ stream }} / {{ consumer }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Consumer Ack Pending",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "jetstream_consumer_num_ack_pending{stream=~\"$stream\"}",
          "legendFormat": "{{ stream }} / {{ consumer }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Stream Storage & Server",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Stream Storage Size",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "jetstream_stream_bytes{stream=~\"$stream\"}",
          "legendFormat": "{{ stream }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Server Connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "nats_server_connections",
          "legendFormat": "{{ server_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Stream Messages",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 27 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "jetstream_stream_total_messages{stream=~\"$stream\"}",
          "legendFormat": "{{ stream }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Consumers",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 27 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "jetstream_stream_consumer_count{stream=~\"$stream\"}",
          "legendFormat": "{{ stream }}",
          "refId": "A"
        }
      ]
    }
  ]
}
