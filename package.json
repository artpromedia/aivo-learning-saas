{
  "name": "aivo-learning-saas",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo build",
    "build:all": "pnpm --filter @aivo/brand build && pnpm --filter @aivo/ui build && pnpm --filter @aivo/marketing build",
    "lint": "turbo lint",
    "lint:all": "eslint .",
    "type-check:all": "pnpm -r --filter './packages/*' type-check",
    "test": "turbo test",
    "test:all": "pnpm --filter @aivo/brand --filter @aivo/ui test",
    "dev": "turbo dev --concurrency=20",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.0.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.44.2"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
